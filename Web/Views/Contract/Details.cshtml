@model GLMS.Enterprise.Core.Entities.Contract

@{
    ViewData["Title"] = "Contract Details";
}

<!-- Page Header -->
<div class="glms-page-header">
    <div>
        <h1 class="glms-page-title">Contract Details</h1>
        <p class="glms-page-subtitle">View contract information and associated service requests.</p>
    </div>
    <div class="d-flex gap-2">
        <a asp-action="Edit" asp-route-id="@Model.Id" class="btn btn-glms-primary btn-icon">
            <i class="bi bi-pencil"></i> Edit
        </a>
        <a asp-action="Index" class="btn btn-glms-secondary btn-icon">
            <i class="bi bi-arrow-left"></i> Back to List
        </a>
    </div>
</div>

<!-- Main Content -->
<div class="row g-4">
    <div class="col-lg-6">
        <div class="glms-card">
            <h5 class="mb-4">Contract Information</h5>
            <div class="detail-row">
                <span class="detail-label">Client</span>
                <span class="detail-value"><strong>@Model.Client?.Name</strong></span>
            </div>
            <div class="detail-row">
                <span class="detail-label">Status</span>
                <span class="detail-value">
                    @switch (Model.Status.ToString())
                    {
                        case "Active":
                            <span class="status-badge status-active">Active</span>
                            break;
                        case "Draft":
                            <span class="status-badge status-draft">Draft</span>
                            break;
                        case "OnHold":
                            <span class="status-badge status-onhold">On Hold</span>
                            break;
                        case "Expired":
                            <span class="status-badge status-expired">Expired</span>
                            break;
                        case "Terminated":
                            <span class="status-badge status-terminated">Terminated</span>
                            break;
                        default:
                            <span class="status-badge status-draft">@Model.Status</span>
                            break;
                    }
                </span>
            </div>
            <div class="detail-row">
                <span class="detail-label">Service Level</span>
                <span class="detail-value">@Model.ServiceLevel</span>
            </div>
            <div class="detail-row">
                <span class="detail-label">Start Date</span>
                <span class="detail-value">@Model.StartDate.ToString("MMM dd, yyyy")</span>
            </div>
            <div class="detail-row">
                <span class="detail-label">End Date</span>
                <span class="detail-value">@Model.EndDate.ToString("MMM dd, yyyy")</span>
            </div>
            <div class="detail-row">
                <span class="detail-label">Created By</span>
                <span class="detail-value">@Model.CreatedBy</span>
            </div>
            <div class="detail-row">
                <span class="detail-label">Created At</span>
                <span class="detail-value">@Model.CreatedAt.ToString("MMM dd, yyyy HH:mm")</span>
            </div>
        </div>
    </div>

    <div class="col-lg-6">
        <div class="glms-card">
            <h5 class="mb-4">Signed Agreement</h5>
            @if (!string.IsNullOrEmpty(Model.PdfFilePath))
            {
                <a asp-action="DownloadPdf" asp-route-id="@Model.Id" class="btn btn-glms-primary btn-icon">
                    <i class="bi bi-download"></i> Download PDF
                </a>
                <p class="text-muted mt-2">@Model.OriginalPdfFileName</p>
            }
            else
            {
                <p class="text-muted">No PDF uploaded.</p>
            }
        </div>

        <div class="glms-card">
            <div class="d-flex justify-content-between align-items-center mb-4">
                <h5 class="mb-0">Service Requests (@Model.ServiceRequests.Count)</h5>
                @if (Model.Status.ToString() == "Active")
                {
                    <a asp-controller="ServiceRequest" asp-action="Create" asp-route-contractId="@Model.Id" class="btn btn-sm btn-glms-primary">
                        <i class="bi bi-plus"></i> Add
                    </a>
                }
            </div>
            @if (Model.ServiceRequests.Any())
            {
                <div class="list-group list-group-flush">
                    @foreach (var req in Model.ServiceRequests)
                    {
                        <a asp-controller="ServiceRequest" asp-action="Details" asp-route-id="@req.Id"
                           class="list-group-item list-group-item-action glms-list-item">
                            <div class="d-flex w-100 justify-content-between align-items-center">
                                <div>
                                    <h6 class="mb-1">@req.Description</h6>
                                    <small class="text-muted">USD @req.AmountUSD.ToString("F2") → ZAR @req.AmountZAR.ToString("F2")</small>
                                </div>
                                <div>
                                    @switch (req.Status.ToString())
                                    {
                                        case "Pending":
                                            <span class="status-badge status-pending">Pending</span>
                                            break;
                                        case "Approved":
                                            <span class="status-badge status-active">Approved</span>
                                            break;
                                        case "InProgress":
                                            <span class="status-badge status-onhold">In Progress</span>
                                            break;
                                        case "Fulfilled":
                                            <span class="status-badge status-active">Fulfilled</span>
                                            break;
                                        case "Rejected":
                                            <span class="status-badge status-expired">Rejected</span>
                                            break;
                                        case "ContractExpired":
                                            <span class="status-badge status-terminated">Expired</span>
                                            break;
                                        default:
                                            <span class="status-badge status-draft">@req.Status</span>
                                            break;
                                    }
                                </div>
                            </div>
                        </a>
                    }
                </div>
            }
            else
            {
                <div class="text-center py-4">
                    <i class="bi bi-clipboard" style="font-size: 2rem; color: var(--glms-text-muted)"></i>
                    <p class="text-muted mt-2">No service requests yet.</p>
                    @if (Model.Status.ToString() == "Active")
                    {
                        <a asp-controller="ServiceRequest" asp-action="Create" asp-route-contractId="@Model.Id" class="btn btn-sm btn-glms-primary">
                            <i class="bi bi-plus"></i> Create First Request
                        </a>
                    }
                </div>
            }
        </div>
    </div>
</div>
