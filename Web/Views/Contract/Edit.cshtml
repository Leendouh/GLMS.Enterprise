@model GLMS.Enterprise.Web.Models.ContractViewModel

@{
    ViewData["Title"] = "Edit Contract";
}

<!-- Page Header -->
<div class="glms-page-header">
    <div>
        <h1 class="glms-page-title">Edit Contract</h1>
        <p class="glms-page-subtitle">Update contract details and documentation.</p>
    </div>
</div>

<!-- Main Content -->
<div class="glms-card">
    <form asp-action="Edit" method="post" enctype="multipart/form-data">
        <input type="hidden" asp-for="Id" />
        <div asp-validation-summary="ModelOnly" class="text-danger"></div>

        <div class="row g-4">
            <div class="col-md-6">
                <div class="form-group">
                    <label asp-for="ClientId" class="form-label">Client</label>
                    <select asp-for="ClientId" asp-items="Model.ClientSelectList" class="form-select" required></select>
                    <span asp-validation-for="ClientId" class="text-danger"></span>
                </div>
            </div>
            <div class="col-md-6">
                <div class="form-group">
                    <label asp-for="Status" class="form-label">Status</label>
                    <select asp-for="Status" class="form-select">
                        <option value="Draft">Draft</option>
                        <option value="Active">Active</option>
                        <option value="OnHold">On Hold</option>
                        <option value="Expired">Expired</option>
                        <option value="Terminated">Terminated</option>
                    </select>
                    <span asp-validation-for="Status" class="text-danger"></span>
                </div>
            </div>
        </div>

        <div class="row g-4 mt-1">
            <div class="col-md-6">
                <div class="form-group">
                    <label asp-for="StartDate" class="form-label">Start Date</label>
                    <input asp-for="StartDate" class="form-control" type="date" required />
                    <span asp-validation-for="StartDate" class="text-danger"></span>
                </div>
            </div>
            <div class="col-md-6">
                <div class="form-group">
                    <label asp-for="EndDate" class="form-label">End Date</label>
                    <input asp-for="EndDate" class="form-control" type="date" required />
                    <span asp-validation-for="EndDate" class="text-danger"></span>
                </div>
            </div>
        </div>

        <div class="form-group mt-4">
            <label asp-for="ServiceLevel" class="form-label">Service Level</label>
            <input asp-for="ServiceLevel" class="form-control" placeholder="e.g., Premium, Standard, Basic" />
            <span asp-validation-for="ServiceLevel" class="text-danger"></span>
        </div>

        <div class="form-group mt-4">
            <label asp-for="PdfFile" class="form-label">Update Signed Agreement (PDF)</label>
            <input asp-for="PdfFile" class="form-control" type="file" accept=".pdf" />
            <span asp-validation-for="PdfFile" class="text-danger"></span>
            @if (!string.IsNullOrEmpty(Model.PdfFilePath))
            {
                <div class="mt-2">
                    <small class="text-muted">Current: @Model.OriginalPdfFileName</small>
                    <br />
                    <a asp-action="DownloadPdf" asp-route-id="@Model.Id" class="btn btn-sm btn-glms-secondary mt-1">
                        <i class="bi bi-download"></i> Download Current
                    </a>
                </div>
            }
        </div>

        <hr class="my-4" style="border-color: var(--glms-border)">

        <div class="d-flex gap-2">
            <button type="submit" class="btn btn-glms-primary btn-icon">
                <i class="bi bi-save"></i> Save Changes
            </button>
            <a asp-action="Index" class="btn btn-glms-secondary btn-icon">
                <i class="bi bi-arrow-left"></i> Back to List
            </a>
        </div>
    </form>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
