@model GLMS.Enterprise.Core.Entities.Contract

@{
    ViewData["Title"] = "Delete Contract";
}

<div class="container mt-4">
    <nav aria-label="breadcrumb">
        <ol class="breadcrumb">
            <li class="breadcrumb-item"><a asp-action="Index">Contracts</a></li>
            <li class="breadcrumb-item active">Delete</li>
        </ol>
    </nav>

    <div class="card">
        <div class="card-header bg-danger text-white">
            <h3 class="mb-0">Delete Contract</h3>
        </div>
        <div class="card-body">
            <div class="alert alert-warning">
                <i class="bi bi-exclamation-triangle"></i>
                <strong>Warning:</strong> This action cannot be undone.
            </div>

            <dl class="row">
                <dt class="col-sm-3">Client:</dt>
                <dd class="col-sm-9"><strong>@Model.Client?.Name</strong></dd>
                <dt class="col-sm-3">Status:</dt>
                <dd class="col-sm-9">@Model.Status</dd>
                <dt class="col-sm-3">Service Level:</dt>
                <dd class="col-sm-9">@Model.ServiceLevel</dd>
                <dt class="col-sm-3">Start Date:</dt>
                <dd class="col-sm-9">@Model.StartDate.ToString("yyyy-MM-dd")</dd>
                <dt class="col-sm-3">End Date:</dt>
                <dd class="col-sm-9">@Model.EndDate.ToString("yyyy-MM-dd")</dd>
                <dt class="col-sm-3">Service Requests:</dt>
                <dd class="col-sm-9">
                    @if (Model.ServiceRequests.Any())
                    {
                        <span class="badge bg-danger">@Model.ServiceRequests.Count requests</span>
                        <p class="text-danger mt-2">
                            <small>This contract has service requests and cannot be deleted.</small>
                        </p>
                    }
                    else
                    {
                        <span class="badge bg-success">No requests</span>
                    }
                </dd>
            </dl>

            <form asp-action="DeleteConfirmed" method="post">
                <input type="hidden" asp-for="Id" />
                <div class="d-flex gap-2">
                    @if (!Model.ServiceRequests.Any())
                    {
                        <button type="submit" class="btn btn-danger">
                            <i class="bi bi-trash"></i> Delete
                        </button>
                    }
                    <a asp-action="Index" class="btn btn-secondary">
                        <i class="bi bi-arrow-left"></i> Back to List
                    </a>
                </div>
            </form>
        </div>
    </div>
</div>
