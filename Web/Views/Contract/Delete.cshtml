@model GLMS.Enterprise.Core.Entities.Contract

@{
    ViewData["Title"] = "Delete Contract";
}

<!-- Page Header -->
<div class="glms-page-header">
    <div>
        <h1 class="glms-page-title">Delete Contract</h1>
        <p class="glms-page-subtitle">Remove this contract from the system.</p>
    </div>
</div>

<!-- Main Content -->
<div class="glms-card">
    <div class="alert alert-warning d-flex align-items-center">
        <i class="bi bi-exclamation-triangle-fill me-2" style="font-size: 1.5rem"></i>
        <div>
            <strong>Warning:</strong> This action cannot be undone. Please review the information below before proceeding.
        </div>
    </div>

    <div class="row g-4">
        <div class="col-md-6">
            <div class="detail-row">
                <span class="detail-label">Client</span>
                <span class="detail-value"><strong>@Model.Client?.Name</strong></span>
            </div>
            <div class="detail-row">
                <span class="detail-label">Status</span>
                <span class="detail-value">@Model.Status</span>
            </div>
            <div class="detail-row">
                <span class="detail-label">Service Level</span>
                <span class="detail-value">@Model.ServiceLevel</span>
            </div>
        </div>
        <div class="col-md-6">
            <div class="detail-row">
                <span class="detail-label">Start Date</span>
                <span class="detail-value">@Model.StartDate.ToString("MMM dd, yyyy")</span>
            </div>
            <div class="detail-row">
                <span class="detail-label">End Date</span>
                <span class="detail-value">@Model.EndDate.ToString("MMM dd, yyyy")</span>
            </div>
            <div class="detail-row">
                <span class="detail-label">Service Requests</span>
                <span class="detail-value">
                    @if (Model.ServiceRequests.Any())
                    {
                        <span class="badge-count bg-danger">@Model.ServiceRequests.Count requests</span>
                        <div class="text-danger mt-1">
                            <small>This contract has service requests and cannot be deleted.</small>
                        </div>
                    }
                    else
                    {
                        <span class="badge-count bg-success">No requests</span>
                    }
                </span>
            </div>
        </div>
    </div>

    <hr class="my-4" style="border-color: var(--glms-border)">

    <form asp-action="DeleteConfirmed" method="post">
        <input type="hidden" asp-for="Id" />
        <div class="d-flex gap-2">
            @if (!Model.ServiceRequests.Any())
            {
                <button type="submit" class="btn btn-glms-danger btn-icon">
                    <i class="bi bi-trash"></i> Delete Contract
                </button>
            }
            <a asp-action="Index" class="btn btn-glms-secondary btn-icon">
                <i class="bi bi-arrow-left"></i> Back to List
            </a>
        </div>
    </form>
</div>
