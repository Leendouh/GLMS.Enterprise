@model GLMS.Enterprise.Core.Entities.Client

@{
    ViewData["Title"] = "Client Details";
}

<!-- Page Header -->
<div class="glms-page-header">
    <div>
        <h1 class="glms-page-title">Client Details</h1>
        <p class="glms-page-subtitle">View comprehensive client information and associated contracts.</p>
    </div>
    <div class="d-flex gap-2">
        <a asp-action="Edit" asp-route-id="@Model.Id" class="btn btn-glms-primary btn-icon">
            <i class="bi bi-pencil"></i> Edit
        </a>
        <a asp-action="Index" class="btn btn-glms-secondary btn-icon">
            <i class="bi bi-arrow-left"></i> Back to List
        </a>
    </div>
</div>

<!-- Main Content -->
<div class="row g-4">
    <div class="col-lg-6">
        <div class="glms-card">
            <h5 class="mb-4">Client Information</h5>
            <div class="detail-row">
                <span class="detail-label">Name</span>
                <span class="detail-value">@Model.Name</span>
            </div>
            <div class="detail-row">
                <span class="detail-label">Contact Email</span>
                <span class="detail-value">
                    <a href="mailto:@Model.ContactEmail" class="text-decoration-none">@Model.ContactEmail</a>
                </span>
            </div>
            <div class="detail-row">
                <span class="detail-label">Contact Phone</span>
                <span class="detail-value">@Model.ContactPhone</span>
            </div>
            <div class="detail-row">
                <span class="detail-label">Region</span>
                <span class="detail-value">@Model.Region</span>
            </div>
            <div class="detail-row">
                <span class="detail-label">Address</span>
                <span class="detail-value">@Model.Address</span>
            </div>
            <div class="detail-row">
                <span class="detail-label">Created At</span>
                <span class="detail-value">@Model.CreatedAt.ToString("MMM dd, yyyy HH:mm")</span>
            </div>
        </div>
    </div>

    <div class="col-lg-6">
        <div class="glms-card">
            <div class="d-flex justify-content-between align-items-center mb-4">
                <h5 class="mb-0">Contracts (@Model.Contracts.Count)</h5>
                @if (Model.Contracts.Any())
                {
                    <a asp-controller="Contract" asp-action="Create" asp-route-clientId="@Model.Id" class="btn btn-sm btn-glms-primary">
                        <i class="bi bi-plus"></i> Add
                    </a>
                }
            </div>
            @if (Model.Contracts.Any())
            {
                <div class="list-group list-group-flush">
                    @foreach (var contract in Model.Contracts)
                    {
                        <a asp-controller="Contract" asp-action="Details" asp-route-id="@contract.Id" 
                           class="list-group-item list-group-item-action glms-list-item">
                            <div class="d-flex w-100 justify-content-between align-items-center">
                                <div>
                                    <h6 class="mb-1">@contract.ServiceLevel</h6>
                                    <small class="text-muted">@contract.StartDate.ToString("MMM dd, yyyy") - @contract.EndDate.ToString("MMM dd, yyyy")</small>
                                </div>
                                <div>
                                    @switch (contract.Status.ToString())
                                    {
                                        case "Active":
                                            <span class="status-badge status-active">Active</span>
                                            break;
                                        case "Pending":
                                            <span class="status-badge status-pending">Pending</span>
                                            break;
                                        case "OnHold":
                                            <span class="status-badge status-onhold">On Hold</span>
                                            break;
                                        case "Expired":
                                            <span class="status-badge status-expired">Expired</span>
                                            break;
                                        case "Terminated":
                                            <span class="status-badge status-terminated">Terminated</span>
                                            break;
                                        default:
                                            <span class="status-badge status-draft">@contract.Status</span>
                                            break;
                                    }
                                </div>
                            </div>
                        </a>
                    }
                </div>
            }
            else
            {
                <div class="text-center py-4">
                    <i class="bi bi-file-earmark-text" style="font-size: 2rem; color: var(--glms-text-muted)"></i>
                    <p class="text-muted mt-2">No contracts yet.</p>
                    <a asp-controller="Contract" asp-action="Create" asp-route-clientId="@Model.Id" class="btn btn-sm btn-glms-primary">
                        <i class="bi bi-plus"></i> Create First Contract
                    </a>
                </div>
            }
        </div>
    </div>
</div>
