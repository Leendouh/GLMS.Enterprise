@model GLMS.Enterprise.Core.Entities.Client

@{
    ViewData["Title"] = "Delete Client";
}

<!-- Page Header -->
<div class="glms-page-header">
    <div>
        <h1 class="glms-page-title">Delete Client</h1>
        <p class="glms-page-subtitle">Remove this client from the system.</p>
    </div>
</div>

<!-- Main Content -->
<div class="glms-card">
    <div class="alert alert-warning d-flex align-items-center">
        <i class="bi bi-exclamation-triangle-fill me-2" style="font-size: 1.5rem"></i>
        <div>
            <strong>Warning:</strong> This action cannot be undone. Please review the information below before proceeding.
        </div>
    </div>

    <div class="row g-4">
        <div class="col-md-6">
            <div class="detail-row">
                <span class="detail-label">Name</span>
                <span class="detail-value">@Model.Name</span>
            </div>
            <div class="detail-row">
                <span class="detail-label">Contact Email</span>
                <span class="detail-value">@Model.ContactEmail</span>
            </div>
            <div class="detail-row">
                <span class="detail-label">Contact Phone</span>
                <span class="detail-value">@Model.ContactPhone</span>
            </div>
        </div>
        <div class="col-md-6">
            <div class="detail-row">
                <span class="detail-label">Region</span>
                <span class="detail-value">@Model.Region</span>
            </div>
            <div class="detail-row">
                <span class="detail-label">Address</span>
                <span class="detail-value">@Model.Address</span>
            </div>
            <div class="detail-row">
                <span class="detail-label">Contracts</span>
                <span class="detail-value">
                    @if (Model.Contracts.Any())
                    {
                        <span class="badge-count bg-danger">@Model.Contracts.Count contracts</span>
                        <div class="text-danger mt-1">
                            <small>This client has contracts and cannot be deleted.</small>
                        </div>
                    }
                    else
                    {
                        <span class="badge-count bg-success">No contracts</span>
                    }
                </span>
            </div>
        </div>
    </div>

    <hr class="my-4" style="border-color: var(--glms-border)">

    <form asp-action="DeleteConfirmed" method="post">
        <input type="hidden" asp-for="Id" />
        <div class="d-flex gap-2">
            @if (!Model.Contracts.Any())
            {
                <button type="submit" class="btn btn-glms-danger btn-icon">
                    <i class="bi bi-trash"></i> Delete Client
                </button>
            }
            <a asp-action="Index" class="btn btn-glms-secondary btn-icon">
                <i class="bi bi-arrow-left"></i> Back to List
            </a>
        </div>
    </form>
</div>
