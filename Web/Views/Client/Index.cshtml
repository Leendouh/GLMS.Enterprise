@model IEnumerable<GLMS.Enterprise.Core.Entities.Client>

@{
    ViewData["Title"] = "Clients";
}

<!-- Page Header -->
<div class="glms-page-header">
    <div>
        <h1 class="glms-page-title">Clients</h1>
        <p class="glms-page-subtitle">Manage your client relationships and contact information.</p>
    </div>
    <div>
        <a asp-action="Create" class="btn btn-glms-primary btn-icon">
            <i class="bi bi-person-plus"></i> Add New Client
        </a>
    </div>
</div>

<!-- Main Content -->
<div class="glms-card">
    @if (Model != null && Model.Any())
    {
        <div class="table-responsive">
            <table class="glms-table">
                <thead>
                    <tr>
                        <th>Client Name</th>
                        <th>Contact Email</th>
                        <th>Contact Phone</th>
                        <th>Region</th>
                        <th>Contracts</th>
                        <th>Created</th>
                        <th>Actions</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var client in Model)
                    {
                        <tr>
                            <td><strong>@client.Name</strong></td>
                            <td>@client.ContactEmail</td>
                            <td>@client.ContactPhone</td>
                            <td>@client.Region</td>
                            <td>
                                <span class="badge-count">@client.Contracts.Count</span>
                            </td>
                            <td>@client.CreatedAt.ToString("MMM dd, yyyy")</td>
                            <td>
                                <div class="btn-group" role="group">
                                    <a asp-action="Details" asp-route-id="@client.Id" class="btn btn-glms-icon btn-info" title="View Details">
                                        <i class="bi bi-eye"></i>
                                    </a>
                                    <a asp-action="Edit" asp-route-id="@client.Id" class="btn btn-glms-icon btn-warning" title="Edit">
                                        <i class="bi bi-pencil"></i>
                                    </a>
                                    <a asp-action="Delete" asp-route-id="@client.Id" class="btn btn-glms-icon btn-danger" title="Delete">
                                        <i class="bi bi-trash"></i>
                                    </a>
                                </div>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    }
    else
    {
        <div class="text-center py-5">
            <i class="bi bi-people" style="font-size: 3rem; color: var(--glms-text-muted)"></i>
            <p class="text-muted mt-3">No clients found. Click "Add New Client" to create your first client.</p>
        </div>
    }
</div>
