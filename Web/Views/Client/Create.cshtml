@model GLMS.Enterprise.Web.Models.ClientViewModel

@{
    ViewData["Title"] = "Create Client";
}

<!-- Page Header -->
<div class="glms-page-header">
    <div>
        <h1 class="glms-page-title">Create Client</h1>
        <p class="glms-page-subtitle">Add a new client to your management system.</p>
    </div>
</div>

<!-- Main Content -->
<div class="glms-card">
    <form asp-action="Create" method="post">
        <div asp-validation-summary="ModelOnly" class="text-danger"></div>

        <div class="row g-4">
            <div class="col-md-6">
                <div class="form-group">
                    <label asp-for="Name" class="form-label"></label>
                    <input asp-for="Name" class="form-control" placeholder="Enter client name" required />
                    <span asp-validation-for="Name" class="text-danger"></span>
                </div>
            </div>
            <div class="col-md-6">
                <div class="form-group">
                    <label asp-for="ContactEmail" class="form-label"></label>
                    <input asp-for="ContactEmail" class="form-control" type="email" placeholder="client@example.com" required />
                    <span asp-validation-for="ContactEmail" class="text-danger"></span>
                </div>
            </div>
        </div>

        <div class="row g-4 mt-1">
            <div class="col-md-6">
                <div class="form-group">
                    <label asp-for="ContactPhone" class="form-label"></label>
                    <input asp-for="ContactPhone" class="form-control" placeholder="+27 XX XXX XXXX" />
                    <span asp-validation-for="ContactPhone" class="text-danger"></span>
                </div>
            </div>
            <div class="col-md-6">
                <div class="form-group">
                    <label asp-for="Region" class="form-label"></label>
                    <input asp-for="Region" class="form-control" placeholder="e.g., Gauteng, Western Cape" />
                    <span asp-validation-for="Region" class="text-danger"></span>
                </div>
            </div>
        </div>

        <div class="form-group mt-4">
            <label asp-for="Address" class="form-label"></label>
            <textarea asp-for="Address" class="form-control" rows="3" placeholder="Enter full address"></textarea>
            <span asp-validation-for="Address" class="text-danger"></span>
        </div>

        <hr class="my-4" style="border-color: var(--glms-border)">

        <div class="d-flex gap-2">
            <button type="submit" class="btn btn-glms-primary btn-icon">
                <i class="bi bi-save"></i> Create Client
            </button>
            <a asp-action="Index" class="btn btn-glms-secondary btn-icon">
                <i class="bi bi-arrow-left"></i> Back to List
            </a>
        </div>
    </form>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
