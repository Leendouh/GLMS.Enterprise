@model GLMS.Enterprise.Web.Models.ServiceRequestViewModel

@{
    ViewData["Title"] = "Edit Service Request";
}

<!-- Page Header -->
<div class="glms-page-header">
    <div>
        <h1 class="glms-page-title">Edit Service Request</h1>
        <p class="glms-page-subtitle">Update service request status and description.</p>
    </div>
</div>

<!-- Main Content -->
<div class="glms-card">
    <form asp-action="Edit" method="post">
        <input type="hidden" asp-for="Id" />
        <div asp-validation-summary="ModelOnly" class="text-danger"></div>

        <div class="row g-4">
            <div class="col-md-6">
                <div class="form-group">
                    <label asp-for="ContractId" class="form-label">Contract</label>
                    <select asp-for="ContractId" asp-items="Model.ContractSelectList" class="form-select" required disabled></select>
                    <span asp-validation-for="ContractId" class="text-danger"></span>
                    <small class="text-muted">Contract cannot be changed after creation.</small>
                </div>
            </div>
            <div class="col-md-6">
                <div class="form-group">
                    <label asp-for="Status" class="form-label">Status</label>
                    <select asp-for="Status" class="form-select">
                        <option value="Pending">Pending</option>
                        <option value="Approved">Approved</option>
                        <option value="InProgress">In Progress</option>
                        <option value="Fulfilled">Fulfilled</option>
                        <option value="Rejected">Rejected</option>
                        <option value="ContractExpired">Contract Expired</option>
                    </select>
                    <span asp-validation-for="Status" class="text-danger"></span>
                </div>
            </div>
        </div>

        <div class="form-group mt-4">
            <label asp-for="Description" class="form-label">Description</label>
            <textarea asp-for="Description" class="form-control" rows="3" placeholder="Describe the service request..." required></textarea>
            <span asp-validation-for="Description" class="text-danger"></span>
        </div>

        <div class="row g-4 mt-1">
            <div class="col-md-4">
                <div class="form-group">
                    <label asp-for="AmountUSD" class="form-label">Amount (USD)</label>
                    <input asp-for="AmountUSD" class="form-control" type="number" step="0.01" readonly />
                    <span asp-validation-for="AmountUSD" class="text-danger"></span>
                </div>
            </div>
            <div class="col-md-4">
                <div class="form-group">
                    <label asp-for="AmountZAR" class="form-label">Amount (ZAR)</label>
                    <input asp-for="AmountZAR" class="form-control" type="number" step="0.01" readonly />
                    <span asp-validation-for="AmountZAR" class="text-danger"></span>
                </div>
            </div>
            <div class="col-md-4">
                <div class="form-group">
                    <label asp-for="ExchangeRateUsed" class="form-label">Rate Used</label>
                    <input asp-for="ExchangeRateUsed" class="form-control" type="number" step="any" readonly />
                    <span asp-validation-for="ExchangeRateUsed" class="text-danger"></span>
                </div>
            </div>
        </div>

        <div class="alert alert-info mt-4">
            <i class="bi bi-info-circle-fill me-2"></i>
            <strong>Note:</strong> Currency amounts cannot be modified after creation. Only status and description can be updated.
        </div>

        <hr class="my-4" style="border-color: var(--glms-border)">

        <div class="d-flex gap-2">
            <button type="submit" class="btn btn-glms-primary btn-icon">
                <i class="bi bi-save"></i> Save Changes
            </button>
            <a asp-action="Index" class="btn btn-glms-secondary btn-icon">
                <i class="bi bi-arrow-left"></i> Back to List
            </a>
        </div>
    </form>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
