@model GLMS.Enterprise.Core.Entities.ServiceRequest

@{
    ViewData["Title"] = "Service Request Details";
}

<!-- Page Header -->
<div class="glms-page-header">
    <div>
        <h1 class="glms-page-title">Service Request Details</h1>
        <p class="glms-page-subtitle">View service request information and currency conversion details.</p>
    </div>
    <div class="d-flex gap-2">
        <a asp-action="Edit" asp-route-id="@Model.Id" class="btn btn-glms-primary btn-icon">
            <i class="bi bi-pencil"></i> Edit
        </a>
        <a asp-action="Index" class="btn btn-glms-secondary btn-icon">
            <i class="bi bi-arrow-left"></i> Back to List
        </a>
    </div>
</div>

<!-- Main Content -->
<div class="row g-4">
    <div class="col-lg-6">
        <div class="glms-card">
            <h5 class="mb-4">Request Information</h5>
            <div class="detail-row">
                <span class="detail-label">Contract</span>
                <span class="detail-value">
                    <strong>@Model.Contract?.Client?.Name</strong>
                    <br />
                    <small class="text-muted">@Model.Contract?.ServiceLevel</small>
                </span>
            </div>
            <div class="detail-row">
                <span class="detail-label">Description</span>
                <span class="detail-value">@Model.Description</span>
            </div>
            <div class="detail-row">
                <span class="detail-label">Status</span>
                <span class="detail-value">
                    @switch (Model.Status.ToString())
                    {
                        case "Pending":
                            <span class="status-badge status-pending">Pending</span>
                            break;
                        case "Approved":
                            <span class="status-badge status-active">Approved</span>
                            break;
                        case "InProgress":
                            <span class="status-badge status-onhold">In Progress</span>
                            break;
                        case "Fulfilled":
                            <span class="status-badge status-active">Fulfilled</span>
                            break;
                        case "Rejected":
                            <span class="status-badge status-expired">Rejected</span>
                            break;
                        case "ContractExpired":
                            <span class="status-badge status-terminated">Expired</span>
                            break;
                        default:
                            <span class="status-badge status-draft">@Model.Status</span>
                            break;
                    }
                </span>
            </div>
            <div class="detail-row">
                <span class="detail-label">Created By</span>
                <span class="detail-value">@Model.CreatedBy</span>
            </div>
            <div class="detail-row">
                <span class="detail-label">Created At</span>
                <span class="detail-value">@Model.CreatedAt.ToString("MMM dd, yyyy HH:mm")</span>
            </div>
        </div>
    </div>

    <div class="col-lg-6">
        <div class="glms-card">
            <h5 class="mb-4">Currency Conversion</h5>
            <div class="detail-row">
                <span class="detail-label">Amount USD</span>
                <span class="detail-value"><strong>USD @Model.AmountUSD.ToString("F2")</strong></span>
            </div>
            <div class="detail-row">
                <span class="detail-label">Exchange Rate</span>
                <span class="detail-value">@Model.ExchangeRateUsed.ToString("F4")</span>
            </div>
            <div class="detail-row">
                <span class="detail-label">Amount ZAR</span>
                <span class="detail-value"><strong class="text-success">ZAR @Model.AmountZAR.ToString("F2")</strong></span>
            </div>
        </div>
    </div>
</div>
