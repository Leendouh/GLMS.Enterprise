@model GLMS.Enterprise.Core.Entities.ServiceRequest

@{
    ViewData["Title"] = "Delete Service Request";
}

<!-- Page Header -->
<div class="glms-page-header">
    <div>
        <h1 class="glms-page-title">Delete Service Request</h1>
        <p class="glms-page-subtitle">Remove this service request from the system.</p>
    </div>
</div>

<!-- Main Content -->
<div class="glms-card">
    <div class="alert alert-warning d-flex align-items-center">
        <i class="bi bi-exclamation-triangle-fill me-2" style="font-size: 1.5rem"></i>
        <div>
            <strong>Warning:</strong> This action cannot be undone. Please review the information below before proceeding.
        </div>
    </div>

    <div class="row g-4">
        <div class="col-md-6">
            <div class="detail-row">
                <span class="detail-label">Contract</span>
                <span class="detail-value"><strong>@Model.Contract?.Client?.Name</strong></span>
            </div>
            <div class="detail-row">
                <span class="detail-label">Description</span>
                <span class="detail-value">@Model.Description</span>
            </div>
            <div class="detail-row">
                <span class="detail-label">Status</span>
                <span class="detail-value">@Model.Status</span>
            </div>
        </div>
        <div class="col-md-6">
            <div class="detail-row">
                <span class="detail-label">Amount USD</span>
                <span class="detail-value">USD @Model.AmountUSD.ToString("F2")</span>
            </div>
            <div class="detail-row">
                <span class="detail-label">Amount ZAR</span>
                <span class="detail-value">ZAR @Model.AmountZAR.ToString("F2")</span>
            </div>
            <div class="detail-row">
                <span class="detail-label">Exchange Rate</span>
                <span class="detail-value">@Model.ExchangeRateUsed.ToString("F4")</span>
            </div>
            <div class="detail-row">
                <span class="detail-label">Created At</span>
                <span class="detail-value">@Model.CreatedAt.ToString("MMM dd, yyyy HH:mm")</span>
            </div>
        </div>
    </div>

    <hr class="my-4" style="border-color: var(--glms-border)">

    <form asp-action="DeleteConfirmed" method="post">
        <input type="hidden" asp-for="Id" />
        <div class="d-flex gap-2">
            <button type="submit" class="btn btn-glms-danger btn-icon">
                <i class="bi bi-trash"></i> Delete Service Request
            </button>
            <a asp-action="Index" class="btn btn-glms-secondary btn-icon">
                <i class="bi bi-arrow-left"></i> Back to List
            </a>
        </div>
    </form>
</div>
