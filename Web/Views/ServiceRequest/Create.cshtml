@model GLMS.Enterprise.Web.Models.ServiceRequestViewModel

@{
    ViewData["Title"] = "Create Service Request";
}

<!-- Page Header -->
<div class="glms-page-header">
    <div>
        <h1 class="glms-page-title">Create Service Request</h1>
        <p class="glms-page-subtitle">Submit a new service request with automatic currency conversion.</p>
    </div>
</div>

<!-- Main Content -->
<div class="glms-card">
    <form asp-action="Create" method="post" id="serviceRequestForm">
        <div asp-validation-summary="ModelOnly" class="text-danger"></div>

        <div class="row g-4">
            <div class="col-md-6">
                <div class="form-group">
                    <label asp-for="ContractId" class="form-label">Contract</label>
                    <select asp-for="ContractId" asp-items="Model.ContractSelectList" class="form-select" required>
                        <option value="">Select a contract...</option>
                    </select>
                    <span asp-validation-for="ContractId" class="text-danger"></span>
                    <small class="text-muted">Only Active contracts are shown.</small>
                </div>
            </div>
            <div class="col-md-6">
                <div class="form-group">
                    <label asp-for="Status" class="form-label">Status</label>
                    <select asp-for="Status" class="form-select">
                        <option value="Pending">Pending</option>
                        <option value="Approved">Approved</option>
                        <option value="InProgress">In Progress</option>
                        <option value="Fulfilled">Fulfilled</option>
                        <option value="Rejected">Rejected</option>
                    </select>
                    <span asp-validation-for="Status" class="text-danger"></span>
                </div>
            </div>
        </div>

        <div class="form-group mt-4">
            <label asp-for="Description" class="form-label">Description</label>
            <textarea asp-for="Description" class="form-control" rows="3" placeholder="Describe the service request..." required></textarea>
            <span asp-validation-for="Description" class="text-danger"></span>
        </div>

        <div class="row g-4 mt-1">
            <div class="col-md-6">
                <div class="form-group">
                    <label asp-for="AmountUSD" class="form-label">Amount (USD)</label>
                    <div class="input-group">
                        <span class="input-group-text">$</span>
                        <input asp-for="AmountUSD" class="form-control" type="number" step="0.01" min="0.01" required id="amountUSD" placeholder="0.00" />
                    </div>
                    <span asp-validation-for="AmountUSD" class="text-danger"></span>
                    <button type="button" class="btn btn-sm btn-glms-secondary mt-2" id="fetchRateBtn">
                        <i class="bi bi-arrow-repeat"></i> Get Live Rate
                    </button>
                    <small class="text-muted d-block mt-1">Current rate: <span id="currentRate">@Model.CurrentExchangeRate.ToString("F4")</span></small>
                </div>
            </div>
            <div class="col-md-6">
                <div class="form-group">
                    <label asp-for="AmountZAR" class="form-label">Amount (ZAR)</label>
                    <div class="input-group">
                        <span class="input-group-text">R</span>
                        <input asp-for="AmountZAR" class="form-control" type="number" step="0.01" readonly id="amountZAR" placeholder="0.00" />
                    </div>
                    <span asp-validation-for="AmountZAR" class="text-danger"></span>
                    <small class="text-muted d-block mt-1">Auto-calculated from USD</small>
                </div>
            </div>
        </div>

        <hr class="my-4" style="border-color: var(--glms-border)">

        <div class="d-flex gap-2">
            <button type="submit" class="btn btn-glms-primary btn-icon">
                <i class="bi bi-save"></i> Create Service Request
            </button>
            <a asp-action="Index" class="btn btn-glms-secondary btn-icon">
                <i class="bi bi-arrow-left"></i> Back to List
            </a>
        </div>
    </form>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
    <script>
        $(document).ready(function() {
            // Auto-calculate ZAR when USD changes
            $('#amountUSD').on('input', function() {
                const usd = parseFloat($(this).val()) || 0;
                const rate = parseFloat($('#currentRate').text()) || 18.50;
                const zar = Math.round(usd * rate * 100) / 100;
                $('#amountZAR').val(zar.toFixed(2));
            });

            // Fetch live rate button
            $('#fetchRateBtn').on('click', function() {
                const btn = $(this);
                btn.prop('disabled', true).html('<i class="bi bi-arrow-repeat spin"></i> Loading...');

                $.get('@Url.Action("GetExchangeRate", "ServiceRequest")', function(data) {
                    if (data.success) {
                        $('#currentRate').text(data.rate.toFixed(4));
                        // Recalculate ZAR with new rate
                        const usd = parseFloat($('#amountUSD').val()) || 0;
                        const zar = Math.round(usd * data.rate * 100) / 100;
                        $('#amountZAR').val(zar.toFixed(2));
                        
                        if (data.source === 'fallback') {
                            alert('Using fallback rate. Live API unavailable.');
                        }
                    } else {
                        alert('Failed to fetch rate. Using fallback.');
                    }
                }).fail(function() {
                    alert('Error fetching rate.');
                }).always(function() {
                    btn.prop('disabled', false).html('<i class="bi bi-arrow-repeat"></i> Get Live Rate');
                });
            });
        });
    </script>
    <style>
        .spin {
            animation: spin 1s linear infinite;
        }
        @@keyframes spin {
            from { transform: rotate(0deg); }
            to { transform: rotate(360deg); }
        }
    </style>
}
