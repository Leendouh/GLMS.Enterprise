@model GLMS.Enterprise.Web.Models.ServiceRequestViewModel

@{
    ViewData["Title"] = "Edit Service Request";
}

<div class="container mt-4">
    <nav aria-label="breadcrumb">
        <ol class="breadcrumb">
            <li class="breadcrumb-item"><a asp-action="Index">Service Requests</a></li>
            <li class="breadcrumb-item active">Edit</li>
        </ol>
    </nav>

    <div class="card">
        <div class="card-header">
            <h3 class="mb-0">Edit Service Request</h3>
        </div>
        <div class="card-body">
            <form asp-action="Edit" method="post">
                <input type="hidden" asp-for="Id" />
                <div asp-validation-summary="ModelOnly" class="text-danger"></div>

                <div class="row mb-3">
                    <div class="col-md-6">
                        <label asp-for="ContractId" class="form-label">Contract</label>
                        <select asp-for="ContractId" asp-items="Model.ContractSelectList" class="form-select" required disabled></select>
                        <span asp-validation-for="ContractId" class="text-danger"></span>
                        <small class="text-muted">Contract cannot be changed after creation.</small>
                    </div>
                    <div class="col-md-6">
                        <label asp-for="Status" class="form-label">Status</label>
                        <select asp-for="Status" class="form-select">
                            <option value="Pending">Pending</option>
                            <option value="Approved">Approved</option>
                            <option value="InProgress">In Progress</option>
                            <option value="Fulfilled">Fulfilled</option>
                            <option value="Rejected">Rejected</option>
                            <option value="ContractExpired">Contract Expired</option>
                        </select>
                        <span asp-validation-for="Status" class="text-danger"></span>
                    </div>
                </div>

                <div class="mb-3">
                    <label asp-for="Description" class="form-label"></label>
                    <textarea asp-for="Description" class="form-control" rows="3" required></textarea>
                    <span asp-validation-for="Description" class="text-danger"></span>
                </div>

                <div class="row mb-3">
                    <div class="col-md-4">
                        <label asp-for="AmountUSD" class="form-label">Amount (USD)</label>
                        <input asp-for="AmountUSD" class="form-control" type="number" step="0.01" readonly />
                        <span asp-validation-for="AmountUSD" class="text-danger"></span>
                    </div>
                    <div class="col-md-4">
                        <label asp-for="AmountZAR" class="form-label">Amount (ZAR)</label>
                        <input asp-for="AmountZAR" class="form-control" type="number" step="0.01" readonly />
                        <span asp-validation-for="AmountZAR" class="text-danger"></span>
                    </div>
                    <div class="col-md-4">
                        <label asp-for="ExchangeRateUsed" class="form-label">Rate Used</label>
                        <input asp-for="ExchangeRateUsed" class="form-control" type="number" step="0.0001" readonly />
                        <span asp-validation-for="ExchangeRateUsed" class="text-danger"></span>
                    </div>
                </div>

                <div class="alert alert-info">
                    <i class="bi bi-info-circle"></i>
                    <strong>Note:</strong> Currency amounts cannot be modified after creation. Only status and description can be updated.
                </div>

                <div class="d-flex gap-2">
                    <button type="submit" class="btn btn-primary">
                        <i class="bi bi-save"></i> Save Changes
                    </button>
                    <a asp-action="Index" class="btn btn-secondary">
                        <i class="bi bi-arrow-left"></i> Back to List
                    </a>
                </div>
            </form>
        </div>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
