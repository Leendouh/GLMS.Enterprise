<!DOCTYPE html>
<html lang="en" data-bs-theme="dark">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content="Global Logistics Management System — Contract, Client and Service Request Management" />
    <title>@ViewData["Title"] — GLMS</title>
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700&display=swap" rel="stylesheet" />
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
</head>
<body>
    <nav class="navbar navbar-expand-lg glms-navbar">
        <div class="container-fluid px-4">
            <a class="navbar-brand glms-brand" asp-controller="Home" asp-action="Index">
                <span class="brand-icon">⬡</span>
                <span class="brand-text">GLMS</span>
                <span class="brand-sub">Logistics</span>
            </a>
            <button class="navbar-toggler border-0" type="button" data-bs-toggle="collapse"
                    data-bs-target="#navbarMain" aria-controls="navbarMain"
                    aria-expanded="false" aria-label="Toggle navigation">
                <i class="bi bi-list fs-4 text-white"></i>
            </button>
            <div class="collapse navbar-collapse" id="navbarMain">
                <ul class="navbar-nav me-auto mb-2 mb-lg-0">
                    <li class="nav-item">
                        <a class="nav-link glms-nav-link" asp-controller="Home" asp-action="Index">
                            <i class="bi bi-grid-3x3-gap me-1"></i>Dashboard
                        </a>
                    </li>
                    <li class="nav-item">
                        <a class="nav-link glms-nav-link" asp-controller="Client" asp-action="Index">
                            <i class="bi bi-people me-1"></i>Clients
                        </a>
                    </li>
                    <li class="nav-item dropdown">
                        <a class="nav-link glms-nav-link dropdown-toggle" href="#" role="button"
                           data-bs-toggle="dropdown" aria-expanded="false">
                            <i class="bi bi-file-earmark-text me-1"></i>Contracts
                        </a>
                        <ul class="dropdown-menu glms-dropdown">
                            <li><a class="dropdown-item" asp-controller="Contract" asp-action="Index">
                                <i class="bi bi-list-ul me-2"></i>All Contracts</a></li>
                            <li><a class="dropdown-item" asp-controller="Contract" asp-action="Create">
                                <i class="bi bi-plus-circle me-2"></i>New Contract</a></li>
                            <li><hr class="dropdown-divider" /></li>
                            <li><a class="dropdown-item" asp-controller="Contract" asp-action="Search">
                                <i class="bi bi-search me-2"></i>Search &amp; Filter</a></li>
                        </ul>
                    </li>
                    <li class="nav-item">
                        <a class="nav-link glms-nav-link" asp-controller="ServiceRequest" asp-action="Index">
                            <i class="bi bi-clipboard-check me-1"></i>Service Requests
                        </a>
                    </li>
                </ul>
                <div class="d-flex align-items-center gap-3">
                    <span class="nav-badge">
                        <i class="bi bi-circle-fill text-success" style="font-size:.6rem"></i>
                        <span class="text-white-50 small">Live</span>
                    </span>
                    <span class="text-white-50 small">TechMove Logistics</span>
                </div>
            </div>
        </div>
    </nav>

    <div class="container-fluid px-4 py-4">
        @if (TempData["Success"] != null)
        {
            <div class="alert alert-success alert-dismissible fade show glms-alert" role="alert">
                <i class="bi bi-check-circle me-2"></i>@TempData["Success"]
                <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
            </div>
        }
        @if (TempData["Error"] != null)
        {
            <div class="alert alert-danger alert-dismissible fade show glms-alert" role="alert">
                <i class="bi bi-exclamation-triangle me-2"></i>@TempData["Error"]
                <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
            </div>
        }
        @if (TempData["Warning"] != null)
        {
            <div class="alert alert-warning alert-dismissible fade show glms-alert" role="alert">
                <i class="bi bi-exclamation-circle me-2"></i>@TempData["Warning"]
                <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
            </div>
        }

        <main role="main">
            @RenderBody()
        </main>
    </div>

    <footer class="glms-footer mt-auto">
        <div class="container-fluid px-4">
            <span>&copy; 2026 TechMove Logistics — GLMS v2.0</span>
            <span class="float-end text-muted small">Lindokuhle Zwane · ST10381088</span>
        </div>
    </footer>

    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
