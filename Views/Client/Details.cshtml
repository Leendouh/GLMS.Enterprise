@model GLMS.Enterprise.Core.Entities.Client

@{
    ViewData["Title"] = "Client Details";
}

<div class="container mt-4">
    <nav aria-label="breadcrumb">
        <ol class="breadcrumb">
            <li class="breadcrumb-item"><a asp-action="Index">Clients</a></li>
            <li class="breadcrumb-item active" aria-current="page">Details</li>
        </ol>
    </nav>

    <div class="card">
        <div class="card-header d-flex justify-content-between align-items-center">
            <h3 class="mb-0">Client Details</h3>
            <div>
                <a asp-action="Edit" asp-route-id="@Model.Id" class="btn btn-warning">
                    <i class="bi bi-pencil"></i> Edit
                </a>
                <a asp-action="Index" class="btn btn-secondary">
                    <i class="bi bi-arrow-left"></i> Back to List
                </a>
            </div>
        </div>
        <div class="card-body">
            <div class="row">
                <div class="col-md-6">
                    <dl class="row">
                        <dt class="col-sm-4">Name:</dt>
                        <dd class="col-sm-8">@Model.Name</dd>

                        <dt class="col-sm-4">Contact Email:</dt>
                        <dd class="col-sm-8">
                            <a href="mailto:@Model.ContactEmail">@Model.ContactEmail</a>
                        </dd>

                        <dt class="col-sm-4">Contact Phone:</dt>
                        <dd class="col-sm-8">@Model.ContactPhone</dd>

                        <dt class="col-sm-4">Region:</dt>
                        <dd class="col-sm-8">@Model.Region</dd>

                        <dt class="col-sm-4">Address:</dt>
                        <dd class="col-sm-8">@Model.Address</dd>

                        <dt class="col-sm-4">Created At:</dt>
                        <dd class="col-sm-8">@Model.CreatedAt.ToString("yyyy-MM-dd HH:mm")</dd>
                    </dl>
                </div>
                <div class="col-md-6">
                    <h5>Contracts (@Model.Contracts.Count)</h5>
                    @if (Model.Contracts.Any())
                    {
                        <div class="list-group">
                            @foreach (var contract in Model.Contracts)
                            {
                                <a asp-controller="Contract" asp-action="Details" asp-route-id="@contract.Id" 
                                   class="list-group-item list-group-item-action">
                                    <div class="d-flex w-100 justify-content-between">
                                        <h6 class="mb-1">@contract.ServiceLevel</h6>
                                        <small>@contract.Status</small>
                                    </div>
                                    <p class="mb-1">@contract.StartDate.ToString("yyyy-MM-dd") to @contract.EndDate.ToString("yyyy-MM-dd")</p>
                                    <small>Created: @contract.CreatedAt.ToString("yyyy-MM-dd")</small>
                                </a>
                            }
                        </div>
                    }
                    else
                    {
                        <p class="text-muted">No contracts yet.</p>
                    }
                </div>
            </div>
        </div>
    </div>
</div>
