@model GLMS.Enterprise.Web.Models.ContractSearchViewModel

@{
    ViewData["Title"] = "Search Contracts";
}

<div class="container mt-4">
    <nav aria-label="breadcrumb">
        <ol class="breadcrumb">
            <li class="breadcrumb-item"><a asp-action="Index">Contracts</a></li>
            <li class="breadcrumb-item active">Search</li>
        </ol>
    </nav>

    <div class="card">
        <div class="card-header">
            <h3 class="mb-0">Search Contracts</h3>
        </div>
        <div class="card-body">
            <form asp-action="Search" method="get">
                <div class="row mb-3">
                    <div class="col-md-3">
                        <label asp-for="StartDateFrom" class="form-label">Start Date From</label>
                        <input asp-for="StartDateFrom" class="form-control" type="date" />
                    </div>
                    <div class="col-md-3">
                        <label asp-for="StartDateTo" class="form-label">Start Date To</label>
                        <input asp-for="StartDateTo" class="form-control" type="date" />
                    </div>
                    <div class="col-md-3">
                        <label asp-for="Status" class="form-label">Status</label>
                        <select asp-for="Status" class="form-select">
                            <option value="">All Statuses</option>
                            <option value="Draft">Draft</option>
                            <option value="Active">Active</option>
                            <option value="OnHold">On Hold</option>
                            <option value="Expired">Expired</option>
                            <option value="Terminated">Terminated</option>
                        </select>
                    </div>
                    <div class="col-md-3 d-flex align-items-end">
                        <button type="submit" class="btn btn-primary w-100">
                            <i class="bi bi-search"></i> Search
                        </button>
                    </div>
                </div>
            </form>
        </div>
    </div>

    @if (Model.HasSearched)
    {
        <div class="card mt-4">
            <div class="card-header">
                <h5 class="mb-0">Results (@Model.Results?.Count ?? 0)</h5>
            </div>
            <div class="card-body">
                @if (Model.Results != null && Model.Results.Any())
                {
                    <div class="table-responsive">
                        <table class="table table-hover">
                            <thead>
                                <tr>
                                    <th>Client</th>
                                    <th>Status</th>
                                    <th>Service Level</th>
                                    <th>Start Date</th>
                                    <th>End Date</th>
                                    <th>Requests</th>
                                    <th>Actions</th>
                                </tr>
                            </thead>
                            <tbody>
                                @foreach (var contract in Model.Results)
                                {
                                    <tr>
                                        <td><strong>@contract.ClientName</strong></td>
                                        <td>
                                            <span class="badge @(contract.Status.ToString() switch
                                            {
                                                "Active" => "bg-success",
                                                "Draft" => "bg-secondary",
                                                "OnHold" => "bg-warning",
                                                "Expired" => "bg-danger",
                                                "Terminated" => "bg-dark",
                                                _ => "bg-secondary"
                                            })">@contract.Status</span>
                                        </td>
                                        <td>@contract.ServiceLevel</td>
                                        <td>@contract.StartDate.ToString("yyyy-MM-dd")</td>
                                        <td>@contract.EndDate.ToString("yyyy-MM-dd")</td>
                                        <td>
                                            <span class="badge bg-info">@contract.ServiceRequestCount</span>
                                        </td>
                                        <td>
                                            <a asp-action="Details" asp-route-id="@contract.Id" class="btn btn-sm btn-info">
                                                <i class="bi bi-eye"></i>
                                            </a>
                                        </td>
                                    </tr>
                                }
                            </tbody>
                        </table>
                    </div>
                }
                else
                {
                    <p class="text-muted">No contracts found matching your criteria.</p>
                }
            </div>
        </div>
    }
</div>
