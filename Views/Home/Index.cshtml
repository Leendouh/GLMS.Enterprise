@model GLMS.Enterprise.Web.Models.DashboardViewModel

@{
    ViewData["Title"] = "Dashboard";
}

<div class="container mt-4">
    <h1 class="mb-4">GLMS Dashboard</h1>

    <div class="row mb-4">
        <div class="col-md-3">
            <div class="card text-white bg-primary mb-3">
                <div class="card-body">
                    <h5 class="card-title">Total Clients</h5>
                    <h2 class="card-text">@Model.TotalClients</h2>
                </div>
            </div>
        </div>
        <div class="col-md-3">
            <div class="card text-white bg-success mb-3">
                <div class="card-body">
                    <h5 class="card-title">Total Contracts</h5>
                    <h2 class="card-text">@Model.TotalContracts</h2>
                </div>
            </div>
        </div>
        <div class="col-md-3">
            <div class="card text-white bg-info mb-3">
                <div class="card-body">
                    <h5 class="card-title">Active Contracts</h5>
                    <h2 class="card-text">@Model.ActiveContracts</h2>
                </div>
            </div>
        </div>
        <div class="col-md-3">
            <div class="card text-white bg-warning mb-3">
                <div class="card-body">
                    <h5 class="card-title">Pending Requests</h5>
                    <h2 class="card-text">@Model.PendingRequests</h2>
                </div>
            </div>
        </div>
    </div>

    <div class="row">
        <div class="col-md-6">
            <div class="card">
                <div class="card-header">
                    <h5 class="card-title mb-0">Recent Contracts</h5>
                </div>
                <div class="card-body">
                    @if (Model.RecentContracts.Any())
                    {
                        <div class="table-responsive">
                            <table class="table table-sm">
                                <thead>
                                    <tr>
                                        <th>Client</th>
                                        <th>Status</th>
                                        <th>Created</th>
                                    </tr>
                                </thead>
                                <tbody>
                                    @foreach (var contract in Model.RecentContracts)
                                    {
                                        <tr>
                                            <td>@contract.Client?.Name</td>
                                            <td>@contract.Status</td>
                                            <td>@contract.CreatedAt.ToString("MM/dd/yyyy")</td>
                                        </tr>
                                    }
                                </tbody>
                            </table>
                        </div>
                    }
                    else
                    {
                        <p class="text-muted">No contracts found.</p>
                    }
                </div>
            </div>
        </div>
        <div class="col-md-6">
            <div class="card">
                <div class="card-header">
                    <h5 class="card-title mb-0">Quick Actions</h5>
                </div>
                <div class="card-body">
                    <div class="d-grid gap-2">
                        <a asp-controller="Client" asp-action="Create" class="btn btn-primary">
                            <i class="bi bi-plus-circle"></i> Add New Client
                        </a>
                        <a asp-controller="Contract" asp-action="Create" class="btn btn-success">
                            <i class="bi bi-file-earmark-text"></i> Create Contract
                        </a>
                        <a asp-controller="ServiceRequest" asp-action="Create" class="btn btn-info">
                            <i class="bi bi-plus-square"></i> New Service Request
                        </a>
                        <a asp-controller="Contract" asp-action="Search" class="btn btn-secondary">
                            <i class="bi bi-search"></i> Search Contracts
                        </a>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>
